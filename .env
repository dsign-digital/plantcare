# ─────────────────────────────────────────
# PlantCare – Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────

# SUPABASE
# Find these in: supabase.com → Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://bbenqnduawyuhegotlub.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_UbQWSrTN3md8MPhDXuePWA_C9S4S1-o

# PLANT.ID
# Find these in: plant.id → Dashboard → API Keys
EXPO_PUBLIC_PLANT_ID_API_KEY=your-plant-id-key-here

# REVENUECAT
# Find these in: app.revenuecat.com → Project → API Keys
# Create separate keys for iOS and Android
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# HOW TO GET EACH KEY:
#
# 1. SUPABASE (supabase.com)
#    - Opret projekt → Settings → API
#    - Kopiér "Project URL" og "anon public" key
#
# 2. PLANT.ID (plant.id)
#    - Opret konto → API Keys → Create new key
#    - Gratis: 100 identifikationer/md
#
# 3. REVENUECAT (app.revenuecat.com)
#    - Opret projekt → "PlantCare"
#    - Apps → Add iOS App + Add Android App
#    - Kopiér public API keys for begge platforme
#    - Opret "Offering" kaldt "premium_monthly"
#    - Opret "Package" kaldt "$rc_monthly" med 29 DKK
# ─────────────────────────────────────────

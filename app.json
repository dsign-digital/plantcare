{
  "expo": {
    "name": "PlantCare",
    "slug": "plantcare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.plantcare",
      "infoPlist": {
        "NSCameraUsageDescription": "PlantCare bruger kameraet til at identificere dine planter.",
        "NSPhotoLibraryUsageDescription": "PlantCare bruger dit fotobibliotek til at identificere planter."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3A2A"
      },
      "package": "com.yourcompany.plantcare",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A3A2A"
        }
      ]
    ],
    "scheme": "plantcare",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
